<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ResumoController"
      styleClass="tela-app"
      stylesheets="@/style.css">

    <HBox styleClass="navbar" spacing="10">
        <Button text="Ganhos" onAction="#irParaGanhos" styleClass="nav-btn"/>
        <Button text="Despesas" onAction="#irParaDespesas" styleClass="nav-btn"/>
        <Button text="Resumo" onAction="#irParaResumo" styleClass="nav-btn, nav-ativo"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Sair" onAction="#sair" styleClass="nav-btn, nav-sair"/>
    </HBox>

    <VBox styleClass="container" spacing="15">
        <Label text="Resumo Financeiro" styleClass="titulo"/>
        <Label fx:id="totalGanhosLabel" styleClass="resumo-ganho"/>
        <Label fx:id="totalDespesasLabel" styleClass="resumo-despesa"/>
        <Label fx:id="saldoLabel" styleClass="resumo-saldo"/>
    </VBox>

</VBox>